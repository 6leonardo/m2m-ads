{
  "name": "m2m-ads",
  "version": "0.1.2",
  "description": "M2M classified service client — library and CLI for machine-to-machine ad exchange",
  "license": "MIT",
  "homepage": "https://m2m-ads.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/6leonardo/m2m-ads.git",
    "directory": "clients/m2m-ads"
  },
  "bugs": {
    "url": "https://github.com/6leonardo/m2m-ads/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "m2m-ads": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "test": "node --import tsx/esm node_modules/.bin/mocha --exit test/client.test.ts --timeout 15000",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "m2m",
    "classified",
    "ads",
    "machine-to-machine",
    "cli"
  ],
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "mocha": "^11.0.0",
    "tsup": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
